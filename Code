        <div style={{ padding:20,maxWidth:1150,margin:"0 auto" }}>
          {apiWarning && (
            <div style={{ background:"rgba(224,153,85,0.08)",border:"1px solid rgba(224,153,85,0.4)",borderRadius:10,padding:"12px 18px",marginBottom:16,fontSize:13,color:"#e09955" }}>
              ⚠️ <strong>Clés API manquantes</strong> — Les prix en temps réel nécessitent Alpha Vantage et/ou FMP. Seul Yahoo Finance (non officiel) est actif. Ajoutez vos clés en haut du code (<code>ALPHA_VANTAGE_KEY</code>, <code>FMP_KEY</code>).
            </div>
          )}
          {lines.length===0 ? (
            <div style={{ textAlign:"center",padding:"60px 20px",color:"#555" }}>
              <div style={{ fontSize:48,marginBottom:16 }}>📭</div>
              <div style={{ fontSize:16,color:"#888",marginBottom:8 }}>Aucune ligne dans le portefeuille</div>
              <div style={{ fontSize:13,color:"#555" }}>Demandez une allocation dans l'assistant et importez-la en un clic.</div>
            </div>
          ) : (
            <>
              {hasPending && (
                <div style={{ background:"rgba(201,169,110,0.08)",border:"1px solid rgba(201,169,110,0.3)",borderRadius:10,padding:"11px 16px",marginBottom:14,fontSize:13,color:"#c9a96e" }}>
                  ✏️ Complétez la quantité et le PRU de chaque ligne, puis cliquez sur "Actualiser les prix".
                </div>
              )}
              <div style={{ display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:12,marginBottom:16 }}>
                {[
                  {label:"Valeur actuelle",value:`${Math.round(totalActuel).toLocaleString('fr-FR')} €`,color:"#c9a96e"},
                  {label:"PRU total",value:`${Math.round(totalPRU).toLocaleString('fr-FR')} €`,color:"#888"},
                  {label:"Plus-value",value:`${totalPnL>=0?"+":""}${Math.round(totalPnL).toLocaleString('fr-FR')} €`,color:totalPnL>=0?"#4a9e6b":"#e05555"},
                  {label:"Performance",value:`${totalPnLPct>=0?"+":""}${totalPnLPct.toFixed(2)}%`,color:totalPnLPct>=0?"#4a9e6b":"#e05555"},
                ].map((k,i)=>(
                  <div key={i} style={{ background:"rgba(15,15,25,0.8)",border:"1px solid rgba(201,169,110,0.2)",borderRadius:10,padding:"14px 16px" }}>
                    <div style={{ fontSize:10,color:"#888",letterSpacing:"0.08em",marginBottom:5 }}>{k.label}</div>
                    <div style={{ fontSize:19,fontWeight:"bold",color:k.color }}>{k.value}</div>
                  </div>
                ))}
              </div>

              {/* Refresh bar */}
              <div style={{ display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12,padding:"10px 16px",background:"rgba(15,15,25,0.6)",border:"1px solid rgba(201,169,110,0.15)",borderRadius:10 }}>
                <div style={{ fontSize:12,color:"#666" }}>
                  {lastRefresh ? `⏱ Dernière actualisation : ${lastRefresh}` : "Aucune actualisation effectuée"}
                </div>
                <button onClick={refreshPrices} disabled={refreshing} style={{ background:refreshing?"rgba(201,169,110,0.1)":"linear-gradient(135deg,#c9a96e,#8b6914)",border:"none",borderRadius:8,padding:"7px 18px",cursor:refreshing?"not-allowed":"pointer",color:refreshing?"#888":"#000",fontWeight:"bold",fontSize:12,fontFamily:"inherit",display:"flex",alignItems:"center",gap:6 }}>
                  <span style={{ display:"inline-block",animation:refreshing?"spin 1s linear infinite":"none" }}>⟳</span>
                  {refreshing?"Actualisation…":"Actualiser les prix (3 sources)"}
                </button>
              </div>

              <div style={{ background:"rgba(15,15,25,0.8)",border:"1px solid rgba(201,169,110,0.2)",borderRadius:12,overflow:"auto" }}>
                <div style={{ padding:"14px 18px",display:"flex",justifyContent:"space-between",alignItems:"center",borderBottom:"1px solid rgba(201,169,110,0.15)" }}>
                  <span style={{ fontSize:13,letterSpacing:"0.1em",color:"#c9a96e",fontWeight:"bold" }}>LIGNES DU PORTEFEUILLE</span>
                  <button onClick={()=>setShowAddForm(!showAddForm)} style={{ background:"rgba(201,169,110,0.1)",border:"1px solid rgba(201,169,110,0.3)",borderRadius:8,padding:"5px 12px",cursor:"pointer",color:"#c9a96e",fontSize:12,fontFamily:"inherit" }}>
                    {showAddForm?"✕ Annuler":"+ Ajouter"}
                  </button>
                </div>

                {showAddForm && (
                  <div style={{ padding:"14px 18px",borderBottom:"1px solid rgba(201,169,110,0.1)",background:"rgba(201,169,110,0.03)",display:"flex",flexWrap:"wrap",gap:10,alignItems:"flex-end" }}>
                    {[["Ticker","ticker","text"],["Nom","nom","text"],["Qté","qte","number"],["PRU €","pru","number"],["Prix actuel €","prixActuel","number"],["Cible %","cible","number"]].map(([lbl,key,type])=>(
                      <div key={key}>
                        <div style={{ fontSize:10,color:"#888",marginBottom:4 }}>{lbl}</div>
                        <input type={type} value={newLine[key]} onChange={e=>setNewLine(p=>({...p,[key]:type==="number"?parseFloat(e.target.value)||0:e.target.value}))}
                          style={{ width:key==="nom"?150:75,background:"rgba(0,0,0,0.4)",border:"1px solid rgba(201,169,110,0.3)",borderRadius:6,padding:"5px 7px",color:"#e8e0d0",fontSize:13,fontFamily:"monospace" }}/>
                      </div>
                    ))}
                    <div>
                      <div style={{ fontSize:10,color:"#888",marginBottom:4 }}>Catégorie</div>
                      <select value={newLine.categorie} onChange={e=>setNewLine(p=>({...p,categorie:e.target.value}))}
                        style={{ background:"rgba(0,0,0,0.6)",border:"1px solid rgba(201,169,110,0.3)",borderRadius:6,padding:"5px 7px",color:"#e8e0d0",fontSize:13,fontFamily:"inherit" }}>
                        {Object.keys(CAT_COLORS).map(c=><option key={c}>{c}</option>)}
                      </select>
                    </div>
                    <button onClick={addLine} style={{ background:"linear-gradient(135deg,#c9a96e,#8b6914)",border:"none",borderRadius:8,padding:"7px 16px",cursor:"pointer",color:"#000",fontWeight:"bold",fontSize:13,fontFamily:"inherit" }}>Ajouter</button>
                  </div>
                )}

                <table>
                  <thead>
                    <tr>
                      <th>Ticker</th><th>Nom</th><th>Cat.</th>
                      <th>Qté</th><th>PRU</th><th>Prix temps réel</th>
                      <th>Sources</th><th>Valeur</th><th>PnL €</th><th>PnL %</th>
                      <th>Poids</th><th>Cible</th><th>Écart</th><th></th>
                    </tr>
                  </thead>
                  <tbody>
                    {lineRows.map(l=>{
                      const pd = priceData[l.ticker];
                      return (
                        <tr key={l.id}>
                          <td><span style={{ fontFamily:"monospace",fontWeight:"bold",color:"#c9a96e" }}>{l.ticker}</span></td>
                          <td style={{ fontSize:12,color:"#aaa",maxWidth:140,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap" }}>{l.nom}</td>
                          <td><span style={{ fontSize:10,padding:"2px 6px",borderRadius:20,background:CAT_COLORS[l.categorie]+"22",color:CAT_COLORS[l.categorie],whiteSpace:"nowrap" }}>{l.categorie}</span></td>
                          <td>{l.ticker!=="CASH"?<EditableCell value={l.qte} onSave={v=>updateLine(l.id,"qte",v)}/>:"—"}</td>
                          <td><EditableCell value={l.pru} onSave={v=>updateLine(l.id,"pru",v)} suffix=" €"/></td>
                          <td>
                            <div style={{ display:"flex",flexDirection:"column",alignItems:"flex-end",gap:2 }}>
                              <EditableCell value={l.prixActuel} onSave={v=>updateLine(l.id,"prixActuel",v)} suffix=" €"/>
                              {pd && <span style={{ fontSize:9,color:"#4a9e6b" }}>● live</span>}
                            </div>
                          </td>
                          <td style={{ fontSize:10 }}>
                            {pd ? <SourceBadges sources={pd.sources}/> : <span style={{ color:"#444" }}>—</span>}
                          </td>
                          <td style={{ fontFamily:"monospace" }}>{Math.round(l.valActuelle).toLocaleString('fr-FR')} €</td>
                          <td style={{ color:l.pnl>=0?"#4a9e6b":"#e05555",fontFamily:"monospace" }}>{l.ticker!=="CASH"?(l.pnl>=0?"+":"")+Math.round(l.pnl).toLocaleString('fr-FR')+" €":"—"}</td>
                          <td style={{ color:l.pnlPct>=0?"#4a9e6b":"#e05555",fontFamily:"monospace" }}>{l.ticker!=="CASH"?(l.pnlPct>=0?"+":"")+l.pnlPct.toFixed(1)+"%":"—"}</td>
                          <td style={{ fontFamily:"monospace" }}>{l.pctActuel.toFixed(1)}%</td>
                          <td><EditableCell value={l.cible} onSave={v=>updateLine(l.id,"cible",v)} suffix="%"/></td>
                          <td style={{ color:Math.abs(l.ecartCible)>3?"#e09955":Math.abs(l.ecartCible)>1?"#e0d555":"#888",fontFamily:"monospace" }}>
                            {l.ecartCible>=0?"+":""}{l.ecartCible.toFixed(1)}%
                          </td>
                          <td><button onClick={()=>deleteLine(l.id)} style={{ background:"none",border:"none",cursor:"pointer",color:"#555",fontSize:14 }}>✕</button></td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
                <div style={{ padding:"10px 18px",fontSize:11,color:"#555" }}>
                  💡 Cliquez sur une valeur pour la modifier • Les prix temps réel sont tirés de la médiane de 3 sources (Yahoo Finance, Alpha Vantage, FMP)
                </div>
              </div>
            </>
          )}
        </div>
      )}

      {/* ── RÉÉQUILIBRAGE ── */}
      {activeTab==="realloc" && (
        <div style={{ padding:20,maxWidth:900,margin:"0 auto" }}>
          {lines.length===0 ? (
            <div style={{ textAlign:"center",padding:"60px 20px" }}>
              <div style={{ fontSize:48,marginBottom:16 }}>📭</div>
              <div style={{ fontSize:14,color:"#888" }}>Importez d'abord une allocation depuis l'assistant.</div>
            </div>
          ) : (
            <>
              <div style={{ background:"rgba(15,15,25,0.8)",border:"1px solid rgba(201,169,110,0.2)",borderRadius:12,padding:22,marginBottom:18 }}>
                <div style={{ fontSize:13,color:"#c9a96e",letterSpacing:"0.1em",fontWeight:"bold",marginBottom:16 }}>ÉCARTS PAR RAPPORT AUX CIBLES</div>
                {lineRows.map(l=>{
                  const col = Math.abs(l.ecartCible)>3?"#e09955":Math.abs(l.ecartCible)>1?"#e0d555":"#4a9e6b";
                  return (
                    <div key={l.id} style={{ marginBottom:14 }}>
                      <div style={{ display:"flex",justifyContent:"space-between",marginBottom:5 }}>
                        <span style={{ fontSize:13 }}><span style={{ color:"#c9a96e",fontFamily:"monospace",fontWeight:"bold" }}>{l.ticker}</span> <span style={{ color:"#888",fontSize:12 }}>{l.nom}</span></span>
                        <span style={{ fontSize:12,fontFamily:"monospace",color:col }}>{l.pctActuel.toFixed(1)}% / {l.cible}% ({l.ecartCible>=0?"+":""}{l.ecartCible.toFixed(1)}%)</span>
                      </div>
                      <div style={{ height:6,background:"rgba(255,255,255,0.05)",borderRadius:3,overflow:"hidden" }}>
                        <div style={{ width:`${Math.min(l.pctActuel,100)}%`,height:"100%",background:`linear-gradient(90deg,${col}66,${col})`,borderRadius:3 }}/>
                      </div>
                    </div>
                  );
                })}
              </div>
              <div style={{ textAlign:"center",marginBottom:18 }}>
                <button onClick={runRealloc} disabled={reallocLoading} style={{ background:reallocLoading?"rgba(201,169,110,0.2)":"linear-gradient(135deg,#c9a96e,#8b6914)",border:"none",borderRadius:12,padding:"13px 36px",cursor:reallocLoading?"not-allowed":"pointer",color:reallocLoading?"#888":"#000",fontWeight:"bold",fontSize:14,fontFamily:"inherit" }}>
                  {reallocLoading?"⏳ Analyse en cours…":"🔄 Lancer l'analyse de rééquilibrage IA"}
                </button>
              </div>
              {reallocResult && (
                <div style={{ background:"rgba(15,15,25,0.9)",border:"1px solid rgba(201,169,110,0.3)",borderRadius:12,padding:22 }}>
                  <div style={{ fontSize:11,color:"#c9a96e",letterSpacing:"0.1em",marginBottom:12,fontWeight:"bold" }}>✦ RECOMMANDATIONS</div>
                  <div style={{ fontSize:14,lineHeight:1.8,color:"#e8e0d0",whiteSpace:"pre-wrap",fontFamily:"Georgia,serif" }}>{reallocResult}</div>
                </div>
              )}
            </>
          )}
        </div>
      )}

      {/* ── CHAT ── */}
      {activeTab==="chat" && (
        <div style={{ display:"flex",flexDirection:"column",height:"calc(100vh - 118px)" }}>
          <div style={{ padding:"10px 14px",display:"flex",gap:8,overflowX:"auto",borderBottom:"1px solid rgba(201,169,110,0.1)",background:"rgba(0,0,0,0.2)" }}>
            {QUICK_PROMPTS.map((p,i)=>(
              <button key={i} onClick={()=>sendMessage(p.text)} disabled={loading} style={{ flexShrink:0,background:"rgba(201,169,110,0.07)",border:"1px solid rgba(201,169,110,0.25)",borderRadius:20,padding:"6px 13px",cursor:"pointer",fontSize:12,color:"#c9a96e",fontFamily:"inherit",whiteSpace:"nowrap",display:"flex",alignItems:"center",gap:5 }}>
                <span>{p.icon}</span>{p.label}
              </button>
            ))}
          </div>
          <div style={{ flex:1,overflowY:"auto",padding:"22px 18px" }}>
            <div style={{ maxWidth:760,margin:"0 auto" }}>
              {messages.map((msg,i)=>(
                <div key={i} className="msg-in"><Message msg={msg} onImport={importAllocation}/></div>
              ))}
              {loading && (
                <div style={{ display:"flex",gap:12,alignItems:"flex-start",marginBottom:20 }}>
                  <div style={{ width:36,height:36,borderRadius:"50%",background:"linear-gradient(135deg,#1a1a2e,#16213e)",display:"flex",alignItems:"center",justifyContent:"center",border:"1px solid #c9a96e33",fontSize:14,color:"#c9a96e" }}>∞</div>
                  <div style={{ background:"rgba(15,15,25,0.9)",border:"1px solid rgba(201,169,110,0.2)",borderRadius:"4px 18px 18px 18px" }}><TypingIndicator/></div>
                </div>
              )}
              <div ref={messagesEndRef}/>
            </div>
          </div>
          <div style={{ padding:"14px 18px",background:"rgba(0,0,0,0.5)",borderTop:"1px solid rgba(201,169,110,0.15)",backdropFilter:"blur(20px)" }}>
            <div style={{ maxWidth:760,margin:"0 auto",display:"flex",gap:10 }}>
              <textarea value={input} onChange={e=>setInput(e.target.value)} onKeyDown={e=>{if(e.key==="Enter"&&!e.shiftKey){e.preventDefault();if(input.trim())sendMessage(input.trim());}}} placeholder="Posez votre question sur votre PEA… (Entrée pour envoyer)" rows={2}
                style={{ flex:1,background:"rgba(15,15,25,0.8)",border:"1px solid rgba(201,169,110,0.3)",borderRadius:12,padding:"11px 15px",color:"#e8e0d0",fontSize:14,fontFamily:"inherit",lineHeight:1.5,resize:"none" }}/>
              <button onClick={()=>{if(input.trim())sendMessage(input.trim());}} disabled={loading||!input.trim()}
                style={{ width:46,height:46,alignSelf:"flex-end",background:input.trim()&&!loading?"linear-gradient(135deg,#c9a96e,#8b6914)":"rgba(201,169,110,0.2)",border:"none",borderRadius:12,cursor:input.trim()&&!loading?"pointer":"not-allowed",fontSize:18,color:input.trim()&&!loading?"#000":"#666" }}>↑</button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
