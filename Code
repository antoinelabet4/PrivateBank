// ── PRICE FETCHER — 3 sources + médiane ────────────────────────────────────
async function fetchYahoo(ticker) {
  try {
    const url = `https://query1.finance.yahoo.com/v8/finance/chart/${ticker}?interval=1d&range=1d`;
    const r = await fetch(`https://api.allorigins.win/raw?url=${encodeURIComponent(url)}`);
    const d = await r.json();
    const price = d?.chart?.result?.[0]?.meta?.regularMarketPrice;
    return price ? parseFloat(price) : null;
  } catch { return null; }
}

async function fetchAlphaVantage(ticker) {
  if (!ALPHA_VANTAGE_KEY) return null;
  try {
    // AV uses base ticker without exchange suffix
    const sym = ticker.split(".")[0];
    const url = `https://www.alphavantage.co/query?function=GLOBAL_QUOTE&symbol=${sym}&apikey=${ALPHA_VANTAGE_KEY}`;
    const r = await fetch(url);
    const d = await r.json();
    const price = d?.["Global Quote"]?.["05. price"];
    return price ? parseFloat(price) : null;
  } catch { return null; }
}

async function fetchFMP(ticker) {
  if (!FMP_KEY) return null;
  try {
    const sym = ticker.replace(".PA","").replace(".DE","").replace(".MI","").replace(".AS","");
    const url = `https://financialmodelingprep.com/api/v3/quote-short/${sym}?apikey=${FMP_KEY}`;
    const r = await fetch(url);
    const d = await r.json();
    return d?.[0]?.price ? parseFloat(d[0].price) : null;
  } catch { return null; }
}

function median(arr) {
  const v = arr.filter(x => x !== null && !isNaN(x)).sort((a,b)=>a-b);
  if (!v.length) return null;
  const m = Math.floor(v.length/2);
  return v.length%2 ? v[m] : (v[m-1]+v[m])/2;
}

async function fetchPrice(ticker) {
  if (ticker === "CASH") return null;
  const [y, av, fmp] = await Promise.allSettled([
    fetchYahoo(ticker), fetchAlphaVantage(ticker), fetchFMP(ticker)
  ]);
  const prices = [
    y.status==="fulfilled" ? y.value : null,
    av.status==="fulfilled" ? av.value : null,
    fmp.status==="fulfilled" ? fmp.value : null,
  ];
  const med = median(prices);
  const sources = ["Yahoo","AlphaVantage","FMP"]
    .filter((_,i) => prices[i] !== null)
    .map((name,i) => {
      const idx = ["Yahoo","AlphaVantage","FMP"].indexOf(name);
      return `${name}: ${prices[idx]?.toFixed(2) ?? "—"}`;
    });
  return { price: med, sources, prices };
}

